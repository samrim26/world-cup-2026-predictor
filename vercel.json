{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "api/live.py", "use": "@vercel/python", "config": { "includeFiles": "src/**" } }
  ],
  "routes": [
    { "src": "/api/live", "dest": "/api/live.py" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
